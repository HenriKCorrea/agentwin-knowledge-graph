flowchart LR
  subgraph SC[Smart City Twin]
    S1[EVChargingStation]
    S2[NGSILD Base fields\nlocation address timestamps]
  end

  subgraph EG[Energy Grid Twin]
    E1[ElectricVehicle]
    E2[UsagePoint Meter VoltageLevel Substation]
  end

  S1 --> T1
  S2 --> T1
  E1 --> T1
  E2 --> T1

  subgraph MAP[Transformation Layer]
    T1[Normalize + Validate + Enrich]
    T2[Unit conversion\nA V to kW]
    T3[Semantic alignment\ncapacity disambiguation]
    T4[Freshness and quality gates]
    T5[Derived fields\nenergyNeeded_kWh requiredPower_kW]
    T1 --> T2 --> T3 --> T4 --> T5
  end

  T5 --> C1
  subgraph CONTRACT[Stable Decision Contract V1]
    C1[EVDemand\nevId socNow socTarget deadline\npMin pMax batteryCapacity]
    C2[ChargerSupply\nstationId status availableSlots\nmaxPower socketType location]
    C3[GridEnvelope\nzoneId maxImportNow\nvoltageBand congestionState\nvalidFrom validTo]
    C4[Global semantics\nunits time identity freshness]
  end

  C1 --> D1
  C2 --> D1
  C3 --> D1
  C4 --> D1

  subgraph DEC[Decision Service]
    D1[Feasibility and optimization]
    D2[Output\nassignment setpoint schedule\nreasonCodes confidence]
    D1 --> D2
  end

  D2 --> A1[Audit trail\nsource fields transform rule ids timestamps]

