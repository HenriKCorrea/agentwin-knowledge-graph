' Type: Symbol
' Zero or One:  |o--
' Exactly One:  ||--
' Zero or Many: }o--
' One or Many:  }|--


' | Type           | Symbol   | Purpose                                       |
' | -------------- | -------- | --------------------------------------------- |
' | Extension      |   <|--   | Specialization of a class in a hierarchy      |
' | Implementation |   <|..   | Realization of an interface by a class        |
' | Composition    |   *--    | The part cannot exist without the whole       |
' | Aggregation    |   o--    | The part can exist independently of the whole |
' | Dependency     |   -->    | The object uses another object                |
' | Dependency     |   ..>    | A weaker form of dependency                   |

@startuml Smart City EV

' enum VehicleType {
'     bicycle
'     bus
'     car
'     caravan
'     motorcycle
'     motorscooter
'     truck
' }

' enum SocketType {
'     Caravan_Mains_Socket
'     CHAdeMO
'     CCS_SAE
'     Dual_CHAdeMO
'     Dual_J_1772
'     Dual_Mennekes
'     J_1772
'     Mennekes
'     Other
'     Tesla
'     Type2
'     Type3
'     Wall_Euro
' }

enum ChargingStationStatus {
    almostEmpty
    almostFull
    empty
    full
    outOfService
    withIncidence
    working
}

enum GeoType {
    Point
    LineString
    Polygon
    MultiPoint
    MultiLineString
    MultiPolygon
}

class Address {
    addressCountry: string
    addressLocality: string
    addressRegion: string
    postOfficeBoxNumber: string
    postalCode: string
    streetAddress: string
}

class GeoLocation {
    type: GeoType
    coordinates: string /' Depends on the type of the location. '/
}

class NGSILDBaseModel {
    ' dataProvider: string
    dateModified: dateTime
    ' dateCreated: dateTime
    ' source: string
    ' alternateName: string
    ' name: string
    ' description: string
    ' owner: string
    ' seeAlso: string
    location: GeoLocation
    address: Address
}

' Spatial-object represents everything that can have a spatial representation. It is superclass of feature and geometry. GeoSPARQL 1.0 is an OGC Standard.Copyright (c) 2012 Open Geospatial Consortium.
class SpatialObject {
    
}

' The class represents the top-level geometry type. This class is equivalent to the UML class GM_Object defined in ISO 19107, and it is superclass of all geometry types. GeoSPARQL 1.0 is an OGC Standard.Copyright (c) 2012 Open Geospatial Consortium.
class Geometry extends SpatialObject {

}

' This class represents the top-level feature type. This class is equivalent to GFI_Feature defined in ISO 19156:2011, and it is superclass of all feature types. GeoSPARQL 1.0 is an OGC Standard.Copyright (c) 2012 Open Geospatial Consortium.
class Feature extends SpatialObject {

}

' Generic class for describing city objects.
class CityObject extends Feature {

}

class CityFurniture extends CityObject {

}

entity EVChargingStation extends NGSILDBaseModel {
    capacity: int /' The total number of vehicles which can be charged at the same time. The total number of sockets can be higher. '/
    ' socketNumber: int /' The total number of sockets offered by this charging station. '/ 
    availableCapacity: int /' The number of vehicles which currently can be charged. '/
    ' allowedVehicleType: VehicleType /' Vehicle type(s) which can be charged. '/
    ' socketType: SocketType /' The type of sockets offered by this station. '/
    ' openingHours: string /' The opening hours of the charging station. '/
    status: ChargingStationStatus /' Status of the charging station. '/
    ' network: string /' The name of the Network, with that the operator cooperates. '/
    ' operator: string /' Charging station's operator. '/
    ' contactPoint: ContactPoint /' Charging station contact point. '/
    amperage: double /' The total amperage offered by the charging station. Units:'Ampers (A) '/
    voltage: double /' The total voltage offered by the charging station. Units:'Volts (V)' '/
    ' chargeType: enum {annualPayment, flat, free, monthlyPayment, other} /'  '/
    ' acceptedPaymentMethod: enum {ByBankTransferInAdvance, ByInvoice, Cash, CheckInAdvance, COD, DirectDebit, GoogleCheckout, PayPal, PaySwarm} /' Type(s) of charge when using this station. Model:'https://schema.org/Text'. Enum:'ByBankTransferInAdvance, ByInvoice, Cash, CheckInAdvance, COD, DirectDebit, GoogleCheckout, PayPal, PaySwarm' '/
}

entity Pole extends CityFurniture {
}

SpatialObject --> SpatialObject : Contains
SpatialObject --> SpatialObject : Within

Feature --> Geometry : hasGeometry

NGSILDBaseModel *-- GeoLocation : location
NGSILDBaseModel *-- Address : address

Pole --> EVChargingStation : refEVChargingStation

@enduml
