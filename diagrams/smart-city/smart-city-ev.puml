' Type: Symbol
' Zero or One:  |o--
' Exactly One:  ||--
' Zero or Many: }o--
' One or Many:  }|--


' | Type           | Symbol   | Purpose                                       |
' | -------------- | -------- | --------------------------------------------- |
' | Extension      |   <|--   | Specialization of a class in a hierarchy      |
' | Implementation |   <|..   | Realization of an interface by a class        |
' | Composition    |   *--    | The part cannot exist without the whole       |
' | Aggregation    |   o--    | The part can exist independently of the whole |
' | Dependency     |   -->    | The object uses another object                |
' | Dependency     |   ..>    | A weaker form of dependency                   |

@startuml Smart City EV

' enum VehicleType {
'     bicycle
'     bus
'     car
'     caravan
'     motorcycle
'     motorscooter
'     truck
' }

' enum SocketType {
'     Caravan_Mains_Socket
'     CHAdeMO
'     CCS_SAE
'     Dual_CHAdeMO
'     Dual_J_1772
'     Dual_Mennekes
'     J_1772
'     Mennekes
'     Other
'     Tesla
'     Type2
'     Type3
'     Wall_Euro
' }

enum ChargingStationStatus {
    almostEmpty
    almostFull
    empty
    full
    outOfService
    withIncidence
    working
}

enum GeoType {
    Point
    LineString
    Polygon
    MultiPoint
    MultiLineString
    MultiPolygon
}

class Address <<abstract>> {
    addressCountry: string
    addressLocality: string
    addressRegion: string
    postOfficeBoxNumber: string
    postalCode: string
    streetAddress: string
}

' <<bridge>> decision:
' - **`GeoLocation`** — the Smart City side of the GeoLocation ↔ Location semantic gap. Uses GeoJSON-typed geometry
'   (type: GeoType, coordinates: string) as opposed to the Energy Grid CIM scalar Cartesian model
'   (xPosition/yPosition). The agent must negotiate this coordinate system mismatch when correlating
'   Smart City geographic entities with grid asset zones (e.g., SubGeographicalRegion → Substation).
class GeoLocation <<bridge>> {
    type: GeoType
    coordinates: string /' Depends on the type of the location. '/
}

class NGSILDBaseModel <<abstract>> {
    ' dataProvider: string
    dateModified: dateTime
    ' dateCreated: dateTime
    ' source: string
    ' alternateName: string
    ' name: string
    ' description: string
    ' owner: string
    ' seeAlso: string
    location: GeoLocation
    address: Address
}

' Spatial-object represents everything that can have a spatial representation. It is superclass of feature and geometry. GeoSPARQL 1.0 is an OGC Standard.Copyright (c) 2012 Open Geospatial Consortium.
class SpatialObject <<abstract>> {
    
}

' The class represents the top-level geometry type. This class is equivalent to the UML class GM_Object defined in ISO 19107, and it is superclass of all geometry types. GeoSPARQL 1.0 is an OGC Standard.Copyright (c) 2012 Open Geospatial Consortium.
class Geometry <<abstract>> extends SpatialObject {

}

' This class represents the top-level feature type. This class is equivalent to GFI_Feature defined in ISO 19156:2011, and it is superclass of all feature types. GeoSPARQL 1.0 is an OGC Standard.Copyright (c) 2012 Open Geospatial Consortium.
class Feature <<abstract>> extends SpatialObject {

}

' Generic class for describing city objects.
class CityObject <<abstract>> extends Feature {

}

class CityFurniture <<abstract>> extends CityObject {

}

' <<key>> decision:
' - **`EVChargingStation`** — the supply side from the Smart City perspective. `capacity` is the total number of vehicles
'   that can charge simultaneously, `availableCapacity` is current availability, `status` maps to UsagePoint.connectionState,
'   and `amperage` maps to UsagePoint.ratedCurrent. This is the entity the Smart City agent queries to answer
'   "which stations are available and what power level do they offer?"
'
' <<bridge>> decision:
' - **`EVChargingStation`** — the Smart City side of the EVChargingStation ↔ UsagePoint semantic gap. The Smart City models
'   the charging station as physical infrastructure with availability counts and status enums, while the Energy Grid models
'   the same socket as a logical UsagePoint with power metrics. Bridging this correspondence is the central semantic
'   challenge the agent must solve.
entity EVChargingStation <<key>> <<bridge>> extends NGSILDBaseModel {
    capacity: int /' The total number of vehicles which can be charged at the same time. The total number of sockets can be higher. '/
    ' socketNumber: int /' The total number of sockets offered by this charging station. '/ 
    availableCapacity: int /' The number of vehicles which currently can be charged. '/
    ' allowedVehicleType: VehicleType /' Vehicle type(s) which can be charged. '/
    ' socketType: SocketType /' The type of sockets offered by this station. '/
    ' openingHours: string /' The opening hours of the charging station. '/
    status: ChargingStationStatus /' Status of the charging station. '/
    ' network: string /' The name of the Network, with that the operator cooperates. '/
    ' operator: string /' Charging station's operator. '/
    ' contactPoint: ContactPoint /' Charging station contact point. '/
    amperage: double /' The total amperage offered by the charging station. Units:'Ampers (A) '/
    voltage: double /' The total voltage offered by the charging station. Units:'Volts (V)' '/
    ' chargeType: enum {annualPayment, flat, free, monthlyPayment, other} /'  '/
    ' acceptedPaymentMethod: enum {ByBankTransferInAdvance, ByInvoice, Cash, CheckInAdvance, COD, DirectDebit, GoogleCheckout, PayPal, PaySwarm} /' Type(s) of charge when using this station. Model:'https://schema.org/Text'. Enum:'ByBankTransferInAdvance, ByInvoice, Cash, CheckInAdvance, COD, DirectDebit, GoogleCheckout, PayPal, PaySwarm' '/
}

entity Pole <<context>> extends CityFurniture {
}

' A parking lot with off-street access. Contains EV charging stations and parking spots.
' <<context>> decision:
' - **`OffStreetParking`** — structural anchor linking EVChargingStation to a geographic zone (via NGSILDBaseModel.location).
'   `availableSpotNumber` provides the parking availability the scenario requires ("parking availability" in methodology.tex).
'   The agent uses this to determine if an EV can physically park before assigning it to a charging station.
entity OffStreetParking <<context>> extends NGSILDBaseModel {
    availableSpotNumber: int /' The number of parking spots available in this parking site. '/
    totalSpotNumber: int /' The total number of spots offered by this parking site. '/
    ' openingHours: string
    ' facilities: enum {electricChargingStation, ...} /' Available amenities including EV charging. '/
}

' An atomic parking space / spot.
' <<context>> decision:
' - **`ParkingSpot`** — individual spot occupancy status; allows the agent to determine whether a specific
'   parking space adjacent to a charging station is free before completing an EV assignment.
entity ParkingSpot <<context>> extends NGSILDBaseModel {
    status: string /' Allowed values: occupied, free, closed. '/
    ' category: enum {offStreet, onStreet}
    ' width: double
    ' length: double
}

SpatialObject --> SpatialObject : Contains
SpatialObject --> SpatialObject : Within

Feature --> Geometry : hasGeometry

NGSILDBaseModel *-- GeoLocation : location
NGSILDBaseModel *-- Address : address

Pole --> EVChargingStation : refEVChargingStation

EVChargingStation --> OffStreetParking : refOffStreetParking /' The off-street parking site this charging station belongs to. '/

OffStreetParking --> ParkingSpot : refParkingSpot /' Individual parking spots in this facility. '/

@enduml
